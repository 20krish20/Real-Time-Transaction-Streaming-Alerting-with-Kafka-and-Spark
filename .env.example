# ============================================================
# Merchant Reconciliation Platform — Environment Variables
#
# Copy this file to .env and fill in your values.
# Never commit .env to git — it is in .gitignore.
#
# Pydantic Settings reads nested config via __ delimiter:
#   KAFKA__BOOTSTRAP_SERVERS maps to settings.kafka.bootstrap_servers
# ============================================================

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=local   # local | staging | production

# ── Kafka (local docker-compose defaults) ─────────────────────────────────────
KAFKA__BOOTSTRAP_SERVERS=localhost:9092
KAFKA__SCHEMA_REGISTRY_URL=http://localhost:8081

# Confluent Cloud — uncomment and populate for cloud deployment
# KAFKA__SECURITY_PROTOCOL=SASL_SSL
# KAFKA__SASL_MECHANISM=PLAIN
# KAFKA__SASL_USERNAME=<confluent-api-key>
# KAFKA__SASL_PASSWORD=<confluent-api-secret>
# KAFKA__SCHEMA_REGISTRY_USERNAME=<sr-api-key>
# KAFKA__SCHEMA_REGISTRY_PASSWORD=<sr-api-secret>

# Topics (override if using non-default names)
# KAFKA__TOPIC_RAW_TRANSACTIONS=raw-transactions
# KAFKA__TOPIC_SETTLEMENT_EXPECTATIONS=settlement-expectations
# KAFKA__TOPIC_RECONCILIATION_ALERTS=reconciliation-alerts
# KAFKA__TOPIC_DLQ_TRANSACTIONS=dlq-transactions

# Producer tuning
# KAFKA__LINGER_MS=10
# KAFKA__BATCH_SIZE=65536

# ── Delta Lake paths ──────────────────────────────────────────────────────────
DELTA__BASE_PATH=dbfs:/merchant-reconciliation/delta
DELTA__CHECKPOINT_BASE=dbfs:/merchant-reconciliation/checkpoints

# Local testing override (no DBFS required)
# DELTA__BASE_PATH=/tmp/merchant-reconciliation/delta
# DELTA__CHECKPOINT_BASE=/tmp/merchant-reconciliation/checkpoints

# ── Streaming tuning ──────────────────────────────────────────────────────────
STREAMING__TRANSACTION_WATERMARK_MINUTES=10
STREAMING__SETTLEMENT_WATERMARK_MINUTES=30
STREAMING__AMOUNT_MISMATCH_TOLERANCE_PCT=0.01
STREAMING__GOLD_FRESHNESS_SLA_MINUTES=5
STREAMING__BRONZE_TRIGGER_SECONDS=10
STREAMING__SILVER_TRIGGER_SECONDS=15
STREAMING__GOLD_TRIGGER_SECONDS=20

# ── Snowflake ─────────────────────────────────────────────────────────────────
SNOWFLAKE__ACCOUNT=<your-account-identifier>   # e.g. xy12345.us-east-1
SNOWFLAKE__USER=svc_reconciliation_pipeline
SNOWFLAKE__PASSWORD=<your-password>            # or use key-pair auth below
# SNOWFLAKE__PRIVATE_KEY_PATH=/path/to/rsa_key.p8
# SNOWFLAKE__PRIVATE_KEY_PASSPHRASE=<optional-passphrase>
SNOWFLAKE__DATABASE=RECONCILIATION_DB
SNOWFLAKE__SCHEMA_NAME=GOLD
SNOWFLAKE__WAREHOUSE=RECONCILIATION_WH
SNOWFLAKE__ROLE=RECONCILIATION_ENGINEER

# ── Observability ─────────────────────────────────────────────────────────────
OBS__LOG_LEVEL=INFO
OBS__PROMETHEUS_PORT=8000
OBS__ENABLE_JSON_LOGGING=true
